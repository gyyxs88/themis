{
  "name": "themis",
  "version": "0.1.0",
  "private": true,
  "description": "A self-hosted Codex app-server shell with Web/Feishu entrypoints and platform-gateway integration.",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "themis": "./themis",
    "themis-platform": "./themis-platform",
    "themis-worker-node": "./themis-worker-node"
  },
  "scripts": {
    "themis": "tsx src/cli/main.ts",
    "themis:platform": "tsx src/cli/platform-main.ts",
    "themis:worker-node": "tsx src/cli/worker-node-main.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "dev:web": "tsx watch --clear-screen=false src/server/main.ts",
    "dev:web:once": "tsx src/server/main.ts",
    "dev:platform": "tsx watch --clear-screen=false src/server/platform-main.ts",
    "dev:platform:once": "tsx src/server/platform-main.ts",
    "start:web": "node dist/server/main.js",
    "start:platform": "node dist/server/platform-main.js",
    "publish:public": "bash scripts/export-public-repo.sh"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@openai/codex-sdk": "^0.118.0",
    "better-sqlite3": "^12.8.0",
    "mysql2": "^3.22.0"
  },
  "overrides": {
    "axios": "1.15.0"
  }
}
