# Themis local configuration
# Generated as the recommended local template. Real shell env vars override this file.
# After editing, restart `npm run dev:web` or `npm run start:web`.

# 服务监听
# LAN Web 服务监听地址。
THEMIS_HOST=0.0.0.0

# LAN Web 服务端口。
THEMIS_PORT=3100

# 单个任务超时时间，单位毫秒。
THEMIS_TASK_TIMEOUT_MS=300000

# Codex 认证
# 显式指定 Codex 认证目录；未配置时使用 ~/.codex。
CODEX_HOME=""

# 可选。直接用 API Key 作为 Codex 认证入口。
# 如果不配，也可以在 Web 里做 ChatGPT 浏览器登录或设备码登录。
CODEX_API_KEY=""

# 飞书渠道
# 飞书企业自建应用的 App ID。
FEISHU_APP_ID=""

# 飞书企业自建应用的 App Secret。
FEISHU_APP_SECRET=""

# 飞书 SDK 日志级别。
FEISHU_LOG_LEVEL=info

# 是否让飞书 SDK 继承 HTTP_PROXY / HTTPS_PROXY。
FEISHU_USE_ENV_PROXY=0

# 飞书顺序延迟桥接里缓存 progress 的静默补发超时，单位毫秒。
FEISHU_PROGRESS_FLUSH_TIMEOUT_MS=60000

# 第三方兼容 Provider
# 兼容 OpenAI provider 的 base URL。
# 这组配置也可以在 Web 设置页里维护并写入 SQLite。
THEMIS_OPENAI_COMPAT_BASE_URL=""

# 兼容 OpenAI provider 的 API Key。
THEMIS_OPENAI_COMPAT_API_KEY=""

# 默认模型名。
THEMIS_OPENAI_COMPAT_MODEL=""

# 供应商显示名。
# 只有在完整配置 baseUrl / apiKey / model 时，这个字段才会参与生效；未填写时运行时默认显示为 OpenAI-Compatible Provider。
THEMIS_OPENAI_COMPAT_NAME=""

# 候选端点列表，使用逗号或换行分隔。
THEMIS_OPENAI_COMPAT_ENDPOINT_CANDIDATES=""

# 兼容通道协议类型。
# 只有在完整配置 baseUrl / apiKey / model 时，这个字段才会参与生效；未填写时默认是 responses。
THEMIS_OPENAI_COMPAT_WIRE_API=""

# 兼容 provider 是否支持 websockets。
# 只有在完整配置 baseUrl / apiKey / model 时，这个字段才会参与生效；未填写时默认是 0。
THEMIS_OPENAI_COMPAT_SUPPORTS_WEBSOCKETS=""

# 可选。显式指定 model catalog JSON 路径。
THEMIS_OPENAI_COMPAT_MODEL_CATALOG_JSON=""
